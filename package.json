{
  "name": "kanet-recharge-app",
  "version": "1.0.0",
  "description": "分销充值助手（合规版）：快捷登陆 GPT + 一键跳转结算。卡/地址手动填写。",
  "main": "main.js",
  "author": "kanet",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kanet.recharge",
    "productName": "分销充值助手",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "updater.js", "index.html", "renderer.js", "package.json"],
    "publish": [{ "provider": "github", "owner": "lianqing123", "repo": "kanet-recharge-app" }],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.business",
      "identity": null
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
